{
  "family": "ENV_PLACEHOLDER-bem14-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "EXECUTION_ROLE_ARN_PLACEHOLDER",
  "taskRoleArn": "TASK_ROLE_ARN_PLACEHOLDER",
  "containerDefinitions": [
    {
      "name": "app",
      "image": "<IMAGE1_NAME>",
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "value": "ENV_PLACEHOLDER"
        },
        {
          "name": "PORT",
          "value": "8080"
        },
        {
          "name": "DB_HOST",
          "value": "DB_HOST_PLACEHOLDER"
        },
        {
          "name": "DB_PORT",
          "value": "5432"
        },
        {
          "name": "DB_NAME",
          "value": "photodb"
        },
        {
          "name": "IMAGES_BUCKET",
          "value": "IMAGES_BUCKET_PLACEHOLDER"
        },
        {
          "name": "CLOUDFRONT_DOMAIN",
          "value": "CLOUDFRONT_DOMAIN_PLACEHOLDER"
        }
      ],
      "secrets": [
        {
          "name": "DB_USERNAME",
          "valueFrom": "DB_SECRET_ARN_PLACEHOLDER:username::"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "DB_SECRET_ARN_PLACEHOLDER:password::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/bem14-app",
          "awslogs-region": "AWS_REGION_PLACEHOLDER",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -q -O /dev/null http://localhost:8080/actuator/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "essential": true
    }
  ]
}
